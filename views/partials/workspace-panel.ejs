<aside class="info-panel" aria-label="Job Order information">
  <section class="panel-card">
    <div class="panel-card-header-row">
      <h2 class="panel-heading">Current Minority Report</h2>
      <a href="/job-orders/<%= view.jobOrder.id %>/minority-report/edit" class="btn btn-sm btn-secondary">New Report</a>
    </div>
    <% if (view.minorityReport) { %>
      <%- include('minority-report-summary', { report: view.minorityReport, formattedAt: view.formatted.minority_report_at }) %>
    <% } else { %>
      <p class="panel-empty">No minority report on file.</p>
      <p><a href="/job-orders/<%= view.jobOrder.id %>/minority-report/edit" class="text-link">Create Minority Report</a></p>
    <% } %>
  </section>

  <section class="panel-card">
    <h2 class="panel-heading">Previous Minority Report</h2>
    <% if (view.minorityReportPrevious) { %>
      <%- include('minority-report-summary', { report: view.minorityReportPrevious, formattedAt: view.formatted.minority_report_previous_at }) %>
    <% } else { %>
      <p class="panel-empty">No previous minority report.</p>
    <% } %>
  </section>

  <section class="panel-card">
    <div class="panel-card-header-row">
      <h2 class="panel-heading">Operator Actions Required</h2>
      <a href="/job-orders/<%= view.jobOrder.id %>/operator-actions" class="btn btn-sm btn-secondary">Manage</a>
    </div>
    <% if (view.openOperatorActions.length) { %>
      <ul class="action-list">
        <% view.openOperatorActions.forEach(function(action) { %>
          <li class="action-item">
            <div class="action-item-header">
              <span class="status-badge status-active"><%= action.status %></span>
              <span class="panel-meta">Owner: <%= action.operator %></span>
            </div>
            <p class="action-text"><%= action.action %></p>
            <p class="panel-meta">Created: <%= view.actionFormatted[action.id].created_at %></p>
            <% if (action.checklist && action.checklist.length) { %>
              <ul class="checklist">
                <% action.checklist.forEach(function(item) { %>
                  <li class="checklist-item<%= item.completed ? ' checklist-item--done' : '' %>">
                    <%= item.completed ? '☑' : '☐' %> <%= item.text %>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p class="panel-empty">No open operator actions.</p>
    <% } %>
  </section>

  <section class="panel-card">
    <h2 class="panel-heading">Timeline</h2>
    <% if (view.timeline.length) { %>
      <ul class="timeline-list">
        <% view.timeline.forEach(function(event) { %>
          <li class="timeline-item">
            <span class="timeline-type"><%= event.event_type %></span>
            <p class="timeline-desc"><%= event.description %></p>
            <% if (event.actor) { %>
              <p class="panel-meta">Actor: <%= event.actor %></p>
            <% } %>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p class="panel-empty">No timeline events.</p>
    <% } %>
  </section>

  <section class="panel-card">
    <h2 class="panel-heading">Risks</h2>
    <% if (view.risks.length) { %>
      <ul class="risk-list">
        <% view.risks.forEach(function(risk) { %>
          <li class="risk-item">
            <div class="risk-header">
              <span class="risk-severity severity-<%= risk.severity %>"><%= risk.severity %></span>
              <span class="risk-status"><%= risk.status %></span>
            </div>
            <p class="panel-body"><%= risk.description %></p>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p class="panel-empty">No risks recorded.</p>
    <% } %>
  </section>
</aside>
