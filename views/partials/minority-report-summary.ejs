  <dt>Current Truth</dt>
  <dd><%= report.current_truth %></dd>
  <dt>Completed</dt>
  <dd><%= report.completed %></dd>
  <dt>Remaining</dt>
  <dd><%= report.remaining %></dd>
  <dt>Risk</dt>
  <dd><%= report.risk %></dd>
  <dt>Next Truth</dt>
  <dd><%= report.next_truth %></dd>
  <dt>Next Action</dt>
  <dd><%= report.next_action %></dd>
  <dt>Target</dt>
  <dd><%= report.target %></dd>
</dl>
