<h3 class="panel-subheading"><%= report.title %></h3>
<p class="panel-meta">Status: <%= report.status %> · Updated: <%= formattedAt %></p>

<dl class="mr-fields">
  <dt>Mission</dt>
  <dd><%= report.mission %></dd>
  <dt>Current Phase</dt>
  <dd><%= report.current_phase %></dd>
  <dt>Human Summary</dt>
